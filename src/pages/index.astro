---
import Layout from "../layouts/Layout.astro";
import Link from "../components/Link.astro";
import Card from "../components/Card.astro";
import Globe from "../components/Globe.vue";
import Technologies from "../components/Technologies.vue";
import Particles from "../components/Particles.vue";
---

<Layout
  title="May Solutions – Softwareentwicklung & IT-Beratung Frankfurt"
  description="May Solutions ist Ihr Partner für individuelle Softwareentwicklung und IT-Beratung in Frankfurt am Main. Webentwicklung, Digitalisierungsberatung und IT-Consulting für den Mittelstand."
>
  <main class="relative mx-auto flex min-h-dvh max-w-7xl flex-col items-center bg-transparent py-4 md:p-0">
    <div class="fixed inset-0 -z-10 mx-auto h-screen bg-[url('/hero.webp')] bg-cover bg-center bg-no-repeat blur-3xl">
    </div>
    <section id="hero" class="relative flex h-[100vh] w-full flex-col items-center justify-center">
      <h1
        class="bg-gradient-to-t from-slate-300/50 to-white bg-clip-text py-4 text-center text-5xl font-bold text-transparent drop-shadow-lg md:text-7xl lg:text-9xl">
        May Solutions
      </h1>
      <h2
        class="text-primary z-10 mt-4 text-center text-xl font-normal uppercase tracking-tight text-gray-400 md:text-2xl md:font-thin lg:text-3xl">
        EXCELLENCE. EXPERTISE. EFFICIENCY.
      </h2>
      <Particles
        class="absolute inset-0"
        :quantity="100"
        :ease="100"
        color="#FFF"
        :staticity="10"
        :refresh="true"
        client:only
      />
    </section>

    <section class="relative flex flex-col items-center bg-gray-950 pb-[500px] xl:pb-40">
      <div class="grid grid-cols-1 gap-10 pt-14 md:grid-cols-2">
        <div class="relative">
          <Globe class="z-0 mx-auto pt-72 md:pt-0" client:only />
        </div>
        <div class="z-10 flex flex-col gap-4 p-4 text-xl text-gray-300 md:p-20">
          <h2 class="text-primary pt-0 text-3xl font-semibold md:pt-10 md:text-5xl">
            Ihr IT-Partner in Frankfurt am Main
          </h2>
          <p class="text-left text-lg font-thin">
            Unser Hauptsitz befindet sich in Frankfurt am Main – einem der bedeutendsten Wirtschaftsstandorte Europas.
            Diese strategische Lage ermöglicht uns eine enge Zusammenarbeit mit Unternehmen aus dem Rhein-Main-Gebiet,
            dem deutschen Mittelstand sowie internationalen Partnern.
          </p>
        </div>
      </div>
    </section>

    <section
      class="relative w-full bg-gradient-to-br from-gray-950/20 from-20% via-gray-900 via-50% to-gray-950/30 to-80% py-40">
      <div class="bg-grid absolute inset-0"></div>
      <h2 class="text-primary z-10 px-4 py-10 text-center text-3xl font-semibold tracking-tighter md:text-5xl">
        OUR WORKS HAVE BEEN TRUSTED BY
      </h2>
      <p class="px-4 text-left text-lg font-thin text-gray-300 md:text-center xl:px-40">
        Wir sind stolz darauf, Lösungen für führende Unternehmen in verschiedenen Branchen implementiert zu haben.
        Unser Engagement für Qualität und Kundenzufriedenheit macht uns zu einem zuverlässigen Partner.
      </p>
      <div
        class="mx-auto grid w-full max-w-6xl grid-cols-1 place-items-center gap-8 px-4 py-14 text-gray-300 md:grid-cols-2 xl:grid-cols-4">
        <a
          href="https://www.soka-bau.de/"
          target="_blank"
          rel="noopener noreferrer"
          class="z-10 w-full text-2xl hover:text-gray-200 md:text-3xl lg:text-4xl">
          <Card title="" body="SOKA-BAU" center />
        </a>
        <a
          href="https://www.mercedes-benz.io/"
          target="_blank"
          rel="noopener noreferrer"
          class="z-10 w-full text-2xl hover:text-gray-200 md:text-3xl lg:text-4xl">
          <Card title="" body="Mercedes-Benz.io" center nowrap />
        </a>
        <a
          href="https://www.lbbw.de"
          target="_blank"
          rel="noopener noreferrer"
          class="z-10 w-full text-2xl hover:text-gray-200 md:text-3xl lg:text-4xl">
          <Card title="" body="LBBW" center={true} />
        </a>
        <a
          href="https://gitlab.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="z-10 w-full text-2xl hover:text-gray-200 md:text-3xl lg:text-4xl">
          <Card title="" body="GitLab" center />
        </a>
      </div>
    </section>

    <section class="relative px-4 py-40">
      <h2 class="text-primary z-10 px-4 py-10 text-center text-3xl font-semibold tracking-tighter md:text-5xl">
        UNSERE LEISTUNGEN
      </h2>
      <p class="px-4 text-left text-lg font-thin text-gray-300 md:text-center xl:px-40">
        Wir entwickeln individuelle Softwarelösungen und bieten IT-Beratung mit modernen Technologien.
        Als Frankfurter IT-Beratungsunternehmen unterstützen wir Mittelstandsunternehmen bei der Digitalisierung
        und helfen Ihnen, Ihre Geschäftsziele zu erreichen.
      </p>
      <Technologies client:only />
      <div class="grid grid-cols-1 gap-10 pt-14 xl:grid-cols-3">
        <Card
          title="WEBENTWICKLUNG"
          body="Wir entwickeln maßgeschneiderte Weblösungen mit modernsten Technologien. Von der Konzeption bis zur Umsetzung liefern wir skalierbare, sichere und performante Webapplikationen für Ihr Unternehmen."
        />

        <Card
          title="IT-BERATUNG"
          body="Als erfahrene IT-Berater in Frankfurt unterstützen wir Sie bei der digitalen Transformation Ihres Unternehmens. Wir bieten strategische Beratung, Planung und Umsetzungsbegleitung für Ihren Projekterfolg."
        />
        <Card
          title="AGILITÄT"
          body="Unser agiler Entwicklungsansatz ermöglicht eine schnelle und flexible Lieferung hochwertiger Softwarelösungen. Wir passen uns Ihren Anforderungen an und halten Ihr Projekt auf Kurs."
        />
      </div>
    </section>

    <section class="flex flex-col items-center pb-48 pt-20">
      <h2 class="text-primary z-10 px-4 py-4 text-center text-3xl font-bold tracking-tighter md:text-5xl">
        KONTAKT
      </h2>
      <p class="pb-6 text-center text-lg font-thin text-gray-400">
        Bereit für Ihr nächstes IT-Projekt? Kontaktieren Sie uns – wir freuen uns auf Ihre Anfrage.
      </p>
      <Link href="mailto:contact@may-solutions.io">
        <span class="text-lg text-gray-400 underline hover:text-sky-500">📨 contact@may-solutions.io</span>
      </Link>
    </section>
  </main>

  <footer
    class="border-px relative bottom-0 left-0 mx-auto flex justify-center border-t border-solid border-gray-500/20 p-2">
    <Link href="/impressum">Impressum</Link>
  </footer>
</Layout>

<style is:global>
  .text-primary {
    @apply bg-gradient-to-t from-slate-400 to-white bg-clip-text text-transparent;
  }
  .bg-grid {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32' fill='none' stroke='rgb(148 163 184 / 0.1)'%3e%3cpath d='M0 .5H31.5V32'/%3e%3c/svg%3e");
    mask: linear-gradient(150deg, transparent 10%, white);
  }
</style>
