---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "May Solutions ist Ihr Partner für Softwareentwicklung und IT-Beratung in Frankfurt am Main. Individuelle Softwarelösungen für den Mittelstand – Webentwicklung, Digitalisierung und IT-Consulting.",
  canonicalUrl = Astro.url.href,
} = Astro.props;

const siteName = "May Solutions";
const siteUrl = "https://may-solutions.io";
const ogImage = `${siteUrl}/og-image.webp`;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "May Solutions UG (haftungsbeschränkt)",
  alternateName: "May Solutions",
  description:
    "Softwareentwicklung und IT-Beratung in Frankfurt am Main. Individuelle Softwarelösungen für Unternehmen im Mittelstand.",
  url: siteUrl,
  email: "contact@may-solutions.io",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Ella-Bergmann-Michel-Str. 3",
    addressLocality: "Frankfurt am Main",
    postalCode: "60438",
    addressRegion: "Hessen",
    addressCountry: "DE",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 50.166,
    longitude: 8.682,
  },
  areaServed: [
    { "@type": "City", name: "Frankfurt am Main" },
    { "@type": "State", name: "Hessen" },
    { "@type": "Country", name: "Deutschland" },
  ],
  serviceType: [
    "Softwareentwicklung",
    "IT-Beratung",
    "Webentwicklung",
    "Digitalisierungsberatung",
    "IT-Consulting",
  ],
  priceRange: "$$",
  knowsLanguage: ["de", "en"],
  founder: {
    "@type": "Person",
    name: "Minh Chi Nguyen",
  },
  legalName: "May Solutions UG (haftungsbeschränkt)",
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <meta
      name="keywords"
      content="Softwareentwicklung Frankfurt, IT Beratung Frankfurt, Webentwicklung Frankfurt, Digitalisierung Mittelstand, IT Consulting Frankfurt, individuelle Software Frankfurt, Webentwicklung Agentur Frankfurt"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:locale:alternate" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Geo tags for local SEO -->
    <meta name="geo.region" content="DE-HE" />
    <meta name="geo.placename" content="Frankfurt am Main" />
    <meta name="geo.position" content="50.166;8.682" />
    <meta name="ICBM" content="50.166, 8.682" />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="de" href={siteUrl} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(localBusinessSchema)}
    />

    <!-- Analytics -->
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="65f48548-1b3a-4e69-901b-3ebb92c754eb"></script>
  </head>
  <body class="min-h-dvh bg-gray-950">
    <slot />
  </body>
</html>
<style is:global>
  html {
    font-family: "Inter", sans-serif;
  }
  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }
</style>
